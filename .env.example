# 数据库（Neon PostgreSQL 推荐）
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# MiniMax AI API Key
# 申请地址: https://api.minimax.chat
MINIMAX_API_KEY=your_minimax_api_key_here

# 应用访问地址（用于生成 Webhook 回调 URL）
NEXT_PUBLIC_APP_URL=http://localhost:3001

# 快速审批密钥（随机字符串，用于 /api/quick-approve 接口鉴权）
QUICK_APPROVE_SECRET=your_random_secret_here

# 钉钉连接器（可选）
# DINGTALK_APP_KEY=your_dingtalk_app_key
# DINGTALK_APP_SECRET=your_dingtalk_app_secret

# 企业微信连接器（可选）
# WECOM_CORP_ID=your_wecom_corp_id
# WECOM_TOKEN=your_wecom_token
# WECOM_ENCODING_AES_KEY=your_wecom_aes_key
